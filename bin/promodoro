#!/usr/bin/env bash
# promodoro — small pomodoro state-machine CLI.
# Designed to feed an ashell custom module via its `status` output and
# to nudge the user with a desktop notification when a phase ends.
# Portable bash 3.2+ — runs on Linux and macOS without coreutils-specific flags.

set -euo pipefail

state_dir="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/promodoro"
state_file="$state_dir/state"

work_secs="${PROMODORO_WORK:-1500}"
break_secs="${PROMODORO_BREAK:-300}"
long_break_secs="${PROMODORO_LONG_BREAK:-900}"
rounds_per_cycle="${PROMODORO_ROUNDS:-4}"
lock_cmd_default="loginctl lock-session"
lock_cmd="${PROMODORO_LOCK_CMD:-$lock_cmd_default}"

mkdir -p "$state_dir"

now() { date +%s; }

load_state() {
  if [[ -f $state_file ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  else
    phase="idle"
    phase_end=0
    round=0
  fi
  paused_phase="${paused_phase:-}"
}

save_state() {
  {
    printf 'phase=%s\nphase_end=%s\nround=%s\n' "$phase" "$phase_end" "$round"
    if [[ -n $paused_phase ]]; then
      printf 'paused_phase=%s\n' "$paused_phase"
    fi
  } > "$state_file"
}

advance() {
  case "$phase" in
    work)
      round=$((round + 1))
      if (( round % rounds_per_cycle == 0 )); then
        phase="long_break"
        phase_end=$(( $(now) + long_break_secs ))
      else
        phase="break"
        phase_end=$(( $(now) + break_secs ))
      fi
      ;;
    *)
      phase="work"
      phase_end=$(( $(now) + work_secs ))
      ;;
  esac
}

notify_phase_change() {
  # $1 = phase we just left (work | break | long_break)
  # $2 = round count at the moment of transition (work's round counter)
  command -v notify-send >/dev/null 2>&1 || return 0
  local prev="$1" prev_round="$2"
  case "$prev" in
    work)
      # Work just ended → offer Lock now / Cancel
      (
        action=$(notify-send --wait \
          --app-name="promodoro" \
          --urgency=normal \
          --action="lock=Lock now" \
          --action="cancel=Cancel" \
          "Pomodoro: work complete" \
          "Round $prev_round done — time for a break" 2>/dev/null) || action=""
        if [[ "$action" == "lock" ]]; then
          sh -c "$lock_cmd" >/dev/null 2>&1 || true
        fi
      ) &
      ;;
    break|long_break)
      notify-send \
        --app-name="promodoro" \
        --urgency=low \
        "Break over" "Back to work" >/dev/null 2>&1 &
      ;;
  esac
  disown -a 2>/dev/null || true
}

cmd_start() {
  load_state
  case "$phase" in
    paused)
      remaining=$phase_end
      phase="${paused_phase:-work}"
      phase_end=$(( $(now) + remaining ))
      paused_phase=""
      save_state
      ;;
    idle)
      advance
      save_state
      ;;
  esac
  cmd_status
}

cmd_pause() {
  load_state
  if [[ $phase != idle && $phase != paused ]]; then
    remaining=$(( phase_end - $(now) ))
    paused_phase="$phase"
    phase="paused"
    phase_end=$remaining
    save_state
  fi
  cmd_status
}

cmd_toggle() {
  load_state
  case "$phase" in
    idle|paused) cmd_start ;;
    *)           cmd_pause ;;
  esac
}

cmd_reset() {
  rm -f "$state_file"
  phase="idle"
  phase_end=0
  round=0
  paused_phase=""
  cmd_status
}

cmd_tick() {
  load_state
  if [[ $phase != idle && $phase != paused && $(now) -ge $phase_end ]]; then
    prev_phase="$phase"
    prev_round="$round"
    advance
    save_state
    notify_phase_change "$prev_phase" "$prev_round"
  fi
  cmd_status
}

cmd_status() {
  load_state
  if [[ $phase == idle ]]; then
    echo "idle"
    return
  fi
  if [[ $phase == paused ]]; then
    remaining=$phase_end
  else
    remaining=$(( phase_end - $(now) ))
    (( remaining < 0 )) && remaining=0
  fi
  mm=$(( remaining / 60 ))
  ss=$(( remaining % 60 ))
  printf '%s %02d:%02d (round %d)\n' "$phase" "$mm" "$ss" "$round"
}

cmd=${1:-status}
shift || true

case "$cmd" in
  start)  cmd_start ;;
  pause)  cmd_pause ;;
  toggle) cmd_toggle ;;
  reset)  cmd_reset ;;
  tick)   cmd_tick ;;
  status) cmd_status ;;
  *)
    echo "usage: promodoro {start|pause|toggle|reset|tick|status}" >&2
    exit 2
    ;;
esac
